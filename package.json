{
  "name": "lianleme-monorepo",
  "private": true,
  "version": "1.0.0",
  "workspaces": [
    "apps/mobile-client",
    "apps/admin-console"
  ],
  "//": "forward extra npm args through root workspace wrappers; root package scripts only; verify with node --test tests/root-package-scripts.test.mjs and npm run dev:admin -- --host 127.0.0.1",
  "scripts": {
    "dev:mobile:h5": "npm --workspace apps/mobile-client run dev:h5 --",
    "dev:mobile:mp": "npm --workspace apps/mobile-client run dev:mp-weixin --",
    "dev:admin": "npm --workspace apps/admin-console run dev --",
    "build:admin": "npm --workspace apps/admin-console run build --",
    "build:mobile:h5": "npm --workspace apps/mobile-client run build:h5 --"
  }
}
