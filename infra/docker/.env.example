# ============ 数据库 ============
POSTGRES_USER=lianleme
POSTGRES_PASSWORD=lianleme123
POSTGRES_DB=lianleme
DATABASE_URL=postgresql+asyncpg://lianleme:lianleme123@postgres:5432/lianleme

# ============ Redis ============
REDIS_URL=redis://redis:6379/0

# ============ MinIO 对象存储 ============
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123
MINIO_ENDPOINT=minio:9000
MINIO_BUCKET=lianleme-photos

# ============ 微信小程序 ============
WECHAT_APP_ID=your_wechat_app_id
WECHAT_APP_SECRET=your_wechat_app_secret

# ============ LLM 默认 Key（系统级，用户未配置时降级使用）============
DEFAULT_LLM_PROVIDER=qwen
OPENAI_API_KEY=sk-your-openai-key
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_VISION_MODEL=gpt-4o
QWEN_API_KEY=your-qwen-api-key
QWEN_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_CHAT_MODEL=qwen3.5-flash-2026-02-23
QWEN_VISION_MODEL=qwen3.5-flash-2026-02-23

# ============ 加密 ============
# AES-256 密钥，用于加密用户存储的 API Key（必须 32 字节）
AES_SECRET_KEY=your-32-byte-secret-key-here!!!!

# ============ 应用 ============
APP_ENV=development
SECRET_KEY=your-jwt-secret-key
