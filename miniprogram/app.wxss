/* 全局样式变量 - 运动科技风：深色基调 + 霓虹强调色 */
page {
  --color-bg: #0D0D1A;
  --color-surface: #1A1A2E;
  --color-surface-2: #16213E;
  --color-primary: #00F5C4;
  --color-primary-dim: rgba(0, 245, 196, 0.15);
  --color-accent: #7B2FFF;
  --color-accent-dim: rgba(123, 47, 255, 0.15);
  --color-text: #FFFFFF;
  --color-text-2: rgba(255, 255, 255, 0.7);
  --color-text-3: rgba(255, 255, 255, 0.4);
  --color-border: rgba(255, 255, 255, 0.08);
  --color-success: #00F5C4;
  --color-warning: #FFB800;
  --color-danger: #FF4D6D;
  --radius-sm: 8rpx;
  --radius-md: 16rpx;
  --radius-lg: 24rpx;
  --radius-xl: 32rpx;
  --font-body: -apple-system, "PingFang SC", sans-serif;

  background-color: var(--color-bg);
  color: var(--color-text);
  font-family: var(--font-body);
}

/* 通用卡片 */
.card {
  background: var(--color-surface);
  border-radius: var(--radius-lg);
  padding: 32rpx;
  border: 1rpx solid var(--color-border);
}

/* 主色按钮 */
.btn-primary {
  background: linear-gradient(135deg, #00F5C4, #7B2FFF);
  color: #0D0D1A;
  font-weight: 700;
  border-radius: var(--radius-xl);
  padding: 24rpx 48rpx;
  text-align: center;
  font-size: 32rpx;
  letter-spacing: 2rpx;
}

/* 次级按钮 */
.btn-outline {
  border: 2rpx solid var(--color-primary);
  color: var(--color-primary);
  border-radius: var(--radius-xl);
  padding: 20rpx 40rpx;
  text-align: center;
  font-size: 28rpx;
}

/* 霓虹徽章 */
.badge-neon {
  display: inline-block;
  padding: 6rpx 20rpx;
  border-radius: 100rpx;
  border: 1rpx solid var(--color-primary);
  color: var(--color-primary);
  font-size: 24rpx;
  background: var(--color-primary-dim);
}

/* 分割线 */
.divider {
  height: 1rpx;
  background: var(--color-border);
  margin: 24rpx 0;
}
