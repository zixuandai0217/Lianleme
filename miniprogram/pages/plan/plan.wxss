/* 训练计划页样式：深色科技风 */
page {
  background: #0D0D0D;
  color: #FFFFFF;
}

.container {
  padding: 0 0 120rpx;
  min-height: 100vh;
}

/* 周视图 Tab */
.week-tab {
  display: flex;
  justify-content: space-around;
  align-items: center;
  padding: 24rpx 16rpx;
  background: #161616;
  border-bottom: 1rpx solid #2A2A2A;
  position: sticky;
  top: 0;
  z-index: 10;
}

.day-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  padding: 16rpx 12rpx;
  border-radius: 16rpx;
  transition: all 0.2s;
}

.day-item.active {
  background: rgba(0, 255, 136, 0.12);
}

.day-label {
  font-size: 28rpx;
  color: #888;
  font-weight: 500;
}

.day-item.active .day-label {
  color: #00FF88;
  font-weight: 700;
}

.day-dot {
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: transparent;
}

.dot-active {
  background: #00FF88;
  box-shadow: 0 0 8rpx #00FF88;
}

/* 动作列表 */
.exercise-list {
  padding: 32rpx 24rpx;
}

.section-title {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
  font-size: 32rpx;
  font-weight: 700;
  color: #FFFFFF;
}

.count-badge {
  font-size: 24rpx;
  color: #00FF88;
  background: rgba(0, 255, 136, 0.12);
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
}

.exercise-card {
  display: flex;
  align-items: center;
  gap: 24rpx;
  background: #1A1A1A;
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  border: 1rpx solid #2A2A2A;
}

.exercise-thumb {
  width: 80rpx;
  height: 80rpx;
  background: #252525;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.thumb-icon {
  font-size: 36rpx;
}

.exercise-info {
  flex: 1;
}

.exercise-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #FFFFFF;
  display: block;
  margin-bottom: 10rpx;
}

.exercise-tags {
  display: flex;
  gap: 10rpx;
  margin-bottom: 8rpx;
  flex-wrap: wrap;
}

.tag {
  font-size: 22rpx;
  padding: 4rpx 14rpx;
  border-radius: 12rpx;
}

.tag-set {
  background: rgba(0, 255, 136, 0.15);
  color: #00FF88;
}

.tag-rep {
  background: rgba(99, 179, 237, 0.15);
  color: #63B3ED;
}

.tag-weight {
  background: rgba(252, 211, 77, 0.15);
  color: #FCD34D;
}

.exercise-tips {
  font-size: 22rpx;
  color: #666;
  display: block;
  line-height: 1.4;
}

.exercise-check {
  flex-shrink: 0;
}

.check-circle {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  border: 2rpx solid #444;
  display: flex;
  align-items: center;
  justify-content: center;
}

.check-circle.checked {
  border-color: #00FF88;
  background: #00FF88;
}

.check-icon {
  font-size: 24rpx;
  color: #000;
  font-weight: bold;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
  padding: 80rpx 0;
}

.empty-icon {
  font-size: 80rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #666;
}

/* 强度调节 */
.intensity-section {
  margin: 32rpx 24rpx;
  background: #1A1A1A;
  border-radius: 24rpx;
  padding: 32rpx;
  border: 1rpx solid #2A2A2A;
}

.intensity-value {
  font-size: 32rpx;
  color: #00FF88;
  font-weight: 700;
}

.intensity-slider {
  margin: 24rpx 0 8rpx;
}

.intensity-labels {
  display: flex;
  justify-content: space-between;
  font-size: 22rpx;
  color: #666;
  margin-bottom: 24rpx;
}

.btn-adjust {
  background: rgba(0, 255, 136, 0.1);
  color: #00FF88;
  border: 1rpx solid rgba(0, 255, 136, 0.3);
  border-radius: 16rpx;
  font-size: 28rpx;
  height: 80rpx;
  line-height: 80rpx;
}

.adjust-feedback {
  display: block;
  margin-top: 16rpx;
  font-size: 24rpx;
  color: #888;
  line-height: 1.5;
}

/* 开始训练按钮 */
.btn-start {
  margin: 0 24rpx;
  background: linear-gradient(135deg, #00FF88, #00CC6A);
  color: #000;
  font-size: 32rpx;
  font-weight: 700;
  border-radius: 24rpx;
  height: 96rpx;
  line-height: 96rpx;
  border: none;
  letter-spacing: 2rpx;
}

/* 加载 */
.loading-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 20rpx;
  padding: 80rpx 0;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid #2A2A2A;
  border-top-color: #00FF88;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  font-size: 26rpx;
  color: #666;
}
