/* 训练动作卡片组件样式 */
.card {
  display: flex;
  align-items: center;
  gap: 20rpx;
  background: #1A1A1A;
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  border: 1rpx solid #2A2A2A;
  transition: all 0.2s;
}

.card-done {
  opacity: 0.6;
  border-color: rgba(0, 255, 136, 0.3);
}

.card-left {
  flex-shrink: 0;
}

.index-badge {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: #252525;
  color: #888;
  font-size: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.card-body {
  flex: 1;
}

.exercise-name {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #FFFFFF;
  margin-bottom: 10rpx;
}

.tags {
  display: flex;
  gap: 10rpx;
  flex-wrap: wrap;
  margin-bottom: 8rpx;
}

.tag {
  font-size: 22rpx;
  padding: 4rpx 14rpx;
  border-radius: 12rpx;
}

.tag-set  { background: rgba(0,255,136,0.15); color: #00FF88; }
.tag-rep  { background: rgba(99,179,237,0.15); color: #63B3ED; }
.tag-weight { background: rgba(252,211,77,0.15); color: #FCD34D; }

.tips {
  display: block;
  font-size: 22rpx;
  color: #666;
  line-height: 1.4;
}

.card-right { flex-shrink: 0; }

.check {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  border: 2rpx solid #444;
  display: flex;
  align-items: center;
  justify-content: center;
}

.check-done {
  background: #00FF88;
  border-color: #00FF88;
}

.check-icon {
  font-size: 24rpx;
  color: #000;
  font-weight: bold;
}
