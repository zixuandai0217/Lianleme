# Why: full-rebuild monorepo ignores old legacy folders while preserving policy files.
# Scope: workspace-wide build outputs, Python caches, node modules, env files.
# Verify: `git status` should only show intended source/config changes.

# ignore macOS Finder metadata; any `.DS_Store` file anywhere in the repository; verify with `git check-ignore -v .DS_Store`.
.DS_Store

node_modules/
dist/
coverage/

__pycache__/
*.pyc
.pytest_cache/
.venv/

.env
.env.*
!.env.example

apps/**/dist/
apps/**/.vite/
services/**/.mypy_cache/
services/**/.ruff_cache/

*.log

# Why: avoid generated artifacts from local uv/pip runs polluting git status.
# Scope: service-local packaging metadata and lock outputs generated during tests.
# Verify: running tests no longer creates new untracked *.egg-info/uv.lock files.
services/**/.venv/
services/**/*.egg-info/
services/**/uv.lock
